    <string name="onboarding_protection_desc">Selecciona qué tan agresivamente deseas bloquear anuncios y rastreadores</string>
    <string name="onboarding_protection_basic">Básico</string>
    <string name="onboarding_protection_basic_desc">Bloquea las principales redes de anuncios. Impacto mínimo en la funcionalidad de los sitios web.</string>
    <string name="onboarding_protection_standard">Estándar</string>
    <string name="onboarding_protection_standard_desc">Bloquea anuncios, rastreadores y analíticas. Buen equilibrio entre protección y compatibilidad.</string>
    <string name="onboarding_protection_strict">Estricto</string>
    <string name="onboarding_protection_strict_desc">Bloqueo máximo. Puede afectar algunas funciones de sitios web, pero ofrece la protección más sólida.</string>
    <string name="onboarding_dns_title">Elige un servidor DNS</string>
    <string name="onboarding_dns_desc">Selecciona un servidor DNS para resolver nombres de dominio. Puedes cambiarlo más tarde en los ajustes.</string>
    <string name="onboarding_vpn_title">Se requiere permiso de VPN</string>
    <string name="onboarding_vpn_desc">BlockAds usa una VPN local para filtrar consultas DNS y bloquear anuncios. Ningún dato sale de tu dispositivo — esta VPN funciona exclusivamente de forma local para interceptar y filtrar solicitudes DNS.</string>
    <string name="onboarding_vpn_grant">Conceder permiso de VPN</string>
    <string name="onboarding_notification_title">Mantente informado</string>
    <string name="onboarding_notification_desc">Permite las notificaciones para ver estadísticas de bloqueo en tiempo real y saber que tu protección está activa. Requerido en Android 13+ para la notificación persistente de la VPN.</string>
    <string name="onboarding_notification_grant">Permitir notificaciones</string>
    <string name="onboarding_battery_title">Mantén la protección activa</string>
    <string name="onboarding_battery_desc">Excluye BlockAds de la optimización de batería para que el servicio VPN permanezca activo en segundo plano y no sea detenido por el sistema.</string>
