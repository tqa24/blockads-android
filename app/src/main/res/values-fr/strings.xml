    <!-- Onboarding -->
    <string name="onboarding_title_1">Bloquez les publicités intelligemment</string>
    <string name="onboarding_desc_1">Bloquez les publicités dans toutes les applications et navigateurs en un seul appui. Utilise la technologie de filtrage DNS — aucun root requis.\n\n🔒 Promesse de confidentialité : nous ne collectons, ne stockons ni ne transmettons jamais vos données de navigation. Tout le traitement s\'effectue uniquement sur votre appareil.</string>
    <string name="onboarding_title_2">Votre vie privée, protégée</string>
    <string name="onboarding_desc_2">Aucune collecte de données. Aucun suivi. Tous les journaux DNS restent uniquement sur votre appareil. Nous ne voyons jamais votre activité de navigation.</string>
    <string name="onboarding_title_3">Gratuit et open source</string>
    <string name="onboarding_desc_3">BlockAds est entièrement gratuit, sans achats intégrés. Notre code source est ouvert à l\'inspection et à la vérification par tous.</string>
    <string name="onboarding_skip">Ignorer</string>
    <string name="onboarding_next">Suivant</string>
    <string name="onboarding_get_started">Commencer</string>
    <string name="onboarding_recommended">★ Recommandé</string>

    <!-- Onboarding: Protection Level -->
    <string name="onboarding_protection_title">Choisir le niveau de protection</string>
    <string name="onboarding_protection_desc">Sélectionnez le niveau d\'agressivité du blocage des publicités et des traqueurs</string>
    <string name="onboarding_protection_basic">Basique</string>
    <string name="onboarding_protection_basic_desc">Bloque les principaux réseaux publicitaires. Impact minimal sur les fonctionnalités des sites web.</string>
    <string name="onboarding_protection_standard">Standard</string>
    <string name="onboarding_protection_standard_desc">Bloque les publicités, traqueurs et analyses. Bon équilibre entre protection et compatibilité.</string>
    <string name="onboarding_protection_strict">Strict</string>
    <string name="onboarding_protection_strict_desc">Blocage maximum. Peut affecter certaines fonctionnalités de sites web, mais offre la protection la plus forte.</string>

    <!-- Onboarding: DNS Server -->
    <string name="onboarding_dns_title">Choisir un serveur DNS</string>
    <string name="onboarding_dns_desc">Sélectionnez un serveur DNS pour la résolution des noms de domaine. Vous pouvez modifier ce paramètre ultérieurement dans les Paramètres.</string>

    <!-- Onboarding: VPN Permission -->
    <string name="onboarding_vpn_title">Permission VPN requise</string>
    <string name="onboarding_vpn_desc">BlockAds utilise un VPN local pour filtrer les requêtes DNS et bloquer les publicités. Aucune donnée ne quitte votre appareil — ce VPN fonctionne uniquement en local pour intercepter et filtrer les requêtes DNS.</string>
    <string name="onboarding_vpn_grant">Accorder la permission VPN</string>

    <!-- Onboarding: Notification Permission -->
    <string name="onboarding_notification_title">Restez informé</string>
    <string name="onboarding_notification_desc">Autorisez les notifications pour voir les statistiques de blocage en temps réel et savoir quand votre protection est active. Requis pour la notification VPN persistante sur Android 13+.</string>
    <string name="onboarding_notification_grant">Autoriser les notifications</string>

    <!-- Onboarding: Battery Optimization -->
    <string name="onboarding_battery_title">Maintenir la protection active</string>
