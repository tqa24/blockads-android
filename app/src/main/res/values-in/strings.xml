    <string name="onboarding_protection_title">Pilih Tingkat Perlindungan</string>
    <string name="onboarding_protection_desc">Pilih seberapa agresif Anda ingin memblokir iklan dan pelacak</string>
    <string name="onboarding_protection_basic">Dasar</string>
    <string name="onboarding_protection_basic_desc">Blokir jaringan iklan utama. Dampak minimal pada fungsionalitas situs web.</string>
    <string name="onboarding_protection_standard">Standar</string>
    <string name="onboarding_protection_standard_desc">Blokir iklan, pelacak, dan analitik. Keseimbangan yang baik antara perlindungan dan kompatibilitas.</string>
    <string name="onboarding_protection_strict">Ketat</string>
    <string name="onboarding_protection_strict_desc">Pemblokiran maksimal. Mungkin memengaruhi beberapa fungsionalitas situs web tetapi memberikan perlindungan terkuat.</string>

    <string name="onboarding_dns_title">Pilih Server DNS</string>
    <string name="onboarding_dns_desc">Pilih server DNS untuk menyelesaikan nama domain. Anda dapat mengubahnya nanti di Pengaturan.</string>

    <string name="onboarding_vpn_title">Izin VPN Diperlukan</string>
    <string name="onboarding_vpn_desc">BlockAds menggunakan VPN lokal untuk menyaring kueri DNS dan memblokir iklan. Tidak ada data yang keluar dari perangkat Anda — VPN ini hanya bekerja secara lokal untuk mencegat dan menyaring permintaan DNS.</string>
    <string name="onboarding_vpn_grant">Berikan Izin VPN</string>

    <string name="onboarding_notification_title">Tetap Terinformasi</string>
    <string name="onboarding_notification_desc">Izinkan notifikasi untuk melihat statistik pemblokiran waktu nyata dan mengetahui saat perlindungan Anda aktif. Diperlukan untuk notifikasi VPN persisten di Android 13+.</string>
    <string name="onboarding_notification_grant">Izinkan Notifikasi</string>

    <string name="onboarding_battery_title">Biarkan Perlindungan Tetap Berjalan</string>
    <string name="onboarding_battery_desc">Kecualikan BlockAds dari pengoptimalan baterai agar layanan VPN tetap aktif di latar belakang dan tidak dihentikan oleh sistem.</string>
    <string name="onboarding_battery_grant">Nonaktifkan Pengoptimalan Baterai</string>

    <string name="onboarding_permission_granted">✓ Izin diberikan</string>

