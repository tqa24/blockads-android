    <!-- Onboarding (Prima Configurazione) -->
    <string name="onboarding_title_1">Blocca gli Annunci in Modo Intelligente</string>
    <string name="onboarding_desc_1">Blocca gli annunci in tutte le app e browser con un tocco. Utilizza la tecnologia di filtraggio DNS — senza bisogno di root.\n\n🔒 Promessa di privacy: Non raccogliamo, memorizziamo o trasmettiamo mai i tuoi dati di navigazione. Tutta l\'elaborazione avviene solo sul tuo dispositivo.</string>
    <string name="onboarding_title_2">La Tua Privacy, Protetta</string>
    <string name="onboarding_desc_2">Nessuna raccolta dati. Nessun tracciamento. Tutti i log DNS rimangono solo sul tuo dispositivo. Non vediamo mai la tua attività di navigazione.</string>
    <string name="onboarding_title_3">Gratuito e Open Source</string>
    <string name="onboarding_desc_3">BlockAds è completamente gratuito senza acquisti in-app. Il nostro codice sorgente è aperto a tutti per essere ispezionato e verificato.</string>
    <string name="onboarding_skip">Salta</string>
    <string name="onboarding_next">Avanti</string>
    <string name="onboarding_get_started">Inizia</string>
    <string name="onboarding_recommended">★ Consigliato</string>

    <!-- Onboarding: Livello di Protezione -->
    <string name="onboarding_protection_title">Scegli il Livello di Protezione</string>
    <string name="onboarding_protection_desc">Seleziona quanto aggressivamente vuoi bloccare annunci e tracker</string>
    <string name="onboarding_protection_basic">Base</string>
    <string name="onboarding_protection_basic_desc">Blocca le principali reti pubblicitarie. Impatto minimo sulla funzionalità dei siti.</string>
    <string name="onboarding_protection_standard">Standard</string>
    <string name="onboarding_protection_standard_desc">Blocca annunci, tracker e analytics. Buon equilibrio tra protezione e compatibilità.</string>
    <string name="onboarding_protection_strict">Severo</string>
    <string name="onboarding_protection_strict_desc">Blocco massimo. Potrebbe influenzare alcune funzionalità dei siti ma offre la protezione più forte.</string>

    <!-- Onboarding: Server DNS -->
    <string name="onboarding_dns_title">Scegli il Server DNS</string>
    <string name="onboarding_dns_desc">Seleziona un server DNS per la risoluzione dei nomi di dominio. Puoi cambiarlo in seguito nelle Impostazioni.</string>

    <!-- Onboarding: Permesso VPN -->
    <string name="onboarding_vpn_title">Permesso VPN Richiesto</string>
    <string name="onboarding_vpn_desc">BlockAds utilizza una VPN locale per filtrare le query DNS e bloccare gli annunci. Nessun dato lascia il tuo dispositivo — questa VPN funziona solo localmente per intercettare e filtrare le richieste DNS.</string>
    <string name="onboarding_vpn_grant">Concedi Permesso VPN</string>

    <!-- Onboarding: Permesso Notifiche -->
    <string name="onboarding_notification_title">Rimani Informato</string>
    <string name="onboarding_notification_desc">Consenti le notifiche per vedere le statistiche di blocco in tempo reale e sapere quando la tua protezione è attiva. Richiesto per la notifica VPN persistente su Android 13+.</string>
    <string name="onboarding_notification_grant">Consenti Notifiche</string>

