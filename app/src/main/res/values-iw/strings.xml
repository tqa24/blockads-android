    <string name="https_filtering_explain_title">איך זה עובד?</string>
    <string name="https_filtering_explain_body">סינון HTTPS מיירט את תעבורת האינטרנט מהדפדפנים שבחרת ומחיל כללי CSS קוסמטיים כדי להסתיר באנרים של פרסומות, שכבות-על ואלמנטים חזותיים אחרים של פרסומות בדפי אינטרנט.\n\nכדי לעשות זאת, יש להתקין במכשירך אישור Root CA מקומי. אישור זה מופק באופן מקומי ולעולם אינו עוזב את הטלפון שלך. אפליקציות בנקאות, שירותי Google ושירותים רגישים אחרים לעולם אינם מיורטים.</string>
    <string name="https_filtering_ca_title">מדריך התקנה</string>
    <string name="https_filtering_ca_desc">בצע את השלבים הבאים כדי להגדיר סינון קוסמטי HTTPS:</string>
    <string name="https_filtering_export_ca">שמור בהורדות (Downloads)</string>
    <string name="https_filtering_cert_saved">האישור נשמר בהורדות!</string>
    <string name="https_filtering_install_steps">1. עבור אל הגדרות → אבטחה → הצפנה והרשאות\n2. הקש על \"התקן אישור\" → \"אישור CA\"\n3. בחר \"BlockAds-RootCA.crt\" מההורדות\n4. אשר את ההתקנה</string>
