    <string name="onboarding_dns_desc">בחר שרת DNS לפענוח שמות דומיין. תוכל לשנות זאת מאוחר יותר בהגדרות.</string>

    <string name="onboarding_vpn_title">נדרשת הרשאת VPN</string>
    <string name="onboarding_vpn_desc">BlockAds משתמשת ב-VPN מקומי כדי לסנן שאילתות DNS ולחסום פרסומות. שום מידע לא יוצא מהמכשיר שלך — ה-VPN הזה פועל באופן מקומי בלבד כדי ליירט ולסנן בקשות DNS.</string>
    <string name="onboarding_vpn_grant">הענק הרשאת VPN</string>

    <string name="onboarding_notification_title">הישאר מעודכן</string>
    <string name="onboarding_notification_desc">אפשר התראות כדי לראות סטטיסטיקות חסימה בזמן אמת ולדעת מתי ההגנה שלך פעילה. נדרש עבור התראת ה-VPN הקבועה ב-Android 13 ומעלה.</string>
