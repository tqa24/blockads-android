    <string name="onboarding_title_1">Bloqueie anúncios de forma inteligente</string>
    <string name="onboarding_desc_1">Bloqueie anúncios em todos os aplicativos e navegadores com um toque. Usa tecnologia de filtragem de DNS — não é necessário root.\n\n🔒 Promessa de privacidade: Nunca coletamos, armazenamos ou transmitimos seus dados de navegação. Todo o processamento ocorre apenas no seu dispositivo.</string>
    <string name="onboarding_title_2">Sua privacidade, protegida</string>
    <string name="onboarding_desc_2">Nenhuma coleta de dados. Nenhum rastreamento. Todos os registros DNS permanecem apenas no seu dispositivo. Nós nunca vemos sua atividade de navegação.</string>
    <string name="onboarding_title_3">Gratuito e de código aberto</string>
    <string name="onboarding_desc_3">O BlockAds é totalmente gratuito, sem compras no aplicativo. Nosso código-fonte é aberto para que qualquer pessoa possa inspecionar e verificar.</string>
    <string name="onboarding_skip">Pular</string>
    <string name="onboarding_next">Próximo</string>
    <string name="onboarding_get_started">Começar</string>
    <string name="onboarding_recommended">★ Recomendado</string>

    <string name="onboarding_protection_title">Escolha o nível de proteção</string>
    <string name="onboarding_protection_desc">Selecione o quão agressivamente você deseja bloquear anúncios e rastreadores</string>
    <string name="onboarding_protection_basic">Básico</string>
    <string name="onboarding_protection_basic_desc">Bloqueia as principais redes de anúncios. Impacto mínimo na funcionalidade dos sites.</string>
    <string name="onboarding_protection_standard">Padrão</string>
    <string name="onboarding_protection_standard_desc">Bloqueia anúncios, rastreadores e análises. Bom equilíbrio entre proteção e compatibilidade.</string>
    <string name="onboarding_protection_strict">Rigoroso</string>
    <string name="onboarding_protection_strict_desc">Bloqueio máximo. Pode afetar algumas funcionalidades de sites, mas oferece a proteção mais forte.</string>

    <string name="onboarding_dns_title">Escolha o servidor DNS</string>
    <string name="onboarding_dns_desc">Selecione um servidor DNS para resolver nomes de domínio. Você pode alterar isso mais tarde nas Configurações.</string>

    <string name="onboarding_vpn_title">Permissão de VPN necessária</string>
    <string name="onboarding_vpn_desc">O BlockAds usa uma VPN local para filtrar consultas DNS e bloquear anúncios. Nenhum dado sai do seu dispositivo — esta VPN funciona apenas localmente para interceptar e filtrar solicitações DNS.</string>
    <string name="onboarding_vpn_grant">Conceder permissão de VPN</string>

    <string name="onboarding_notification_title">Mantenha-se informado</string>
    <string name="onboarding_notification_desc">Permita que as notificações vejam as estatísticas de bloqueio em tempo real e saibam quando sua proteção está ativa. Necessário para a notificação de VPN persistente no Android 13+.</string>
    <string name="onboarding_notification_grant">Permitir notificações</string>

    <string name="onboarding_battery_title">Mantenha a proteção em execução</string>
    <string name="onboarding_battery_desc">Exclua o BlockAds da otimização de bateria para que o serviço VPN permaneça ativo em segundo plano e não seja encerrado pelo sistema.</string>
    <string name="onboarding_battery_grant">Desativar otimização de bateria</string>

    <string name="onboarding_permission_granted">✓ Permissão concedida</string>

