    <string name="https_filtering_step1_desc">Скачайте корневой сертификат CA на ваше устройство</string>
    <string name="https_filtering_step2_title">Шаг 2: Установить сертификат</string>
    <string name="https_filtering_step2_desc">Установите сертификат на ваше устройство:</string>
