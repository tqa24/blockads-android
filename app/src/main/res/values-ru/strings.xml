    <!-- Onboarding -->
    <string name="onboarding_title_1">Умная блокировка рекламы</string>
    <string name="onboarding_desc_1">Блокируйте рекламу во всех приложениях и браузерах одним нажатием. Используется DNS-фильтрация — root-права не нужны.\n\n🔒 Обещание конфиденциальности: мы никогда не собираем, не храним и не передаём данные о вашем просмотре. Вся обработка выполняется только на вашем устройстве.</string>
    <string name="onboarding_title_2">Ваша конфиденциальность под защитой</string>
    <string name="onboarding_desc_2">Без сбора данных. Без отслеживания. Все DNS-журналы хранятся только на вашем устройстве. Мы никогда не видим вашу активность в интернете.</string>
    <string name="onboarding_title_3">Бесплатно и с открытым исходным кодом</string>
    <string name="onboarding_desc_3">BlockAds полностью бесплатен и без встроенных покупок. Исходный код открыт — любой может проверить и убедиться.</string>
    <string name="onboarding_skip">Пропустить</string>
    <string name="onboarding_next">Далее</string>
    <string name="onboarding_get_started">Начать</string>
    <string name="onboarding_recommended">★ Рекомендуется</string>

    <!-- Onboarding: Protection Level -->
    <string name="onboarding_protection_title">Выберите уровень защиты</string>
    <string name="onboarding_protection_desc">Выберите, насколько строго блокировать рекламу и трекеры</string>
    <string name="onboarding_protection_basic">Базовый</string>
    <string name="onboarding_protection_basic_desc">Блокирует крупные рекламные сети. Минимально влияет на работу сайтов.</string>
    <string name="onboarding_protection_standard">Стандартный</string>
    <string name="onboarding_protection_standard_desc">Блокирует рекламу, трекеры и аналитику. Хороший баланс защиты и совместимости.</string>
    <string name="onboarding_protection_strict">Строгий</string>
    <string name="onboarding_protection_strict_desc">Максимальная блокировка. Может повлиять на работу некоторых сайтов, но даёт самую сильную защиту.</string>

    <!-- Onboarding: DNS Server -->
    <string name="onboarding_dns_title">Выберите DNS-сервер</string>
    <string name="onboarding_dns_desc">Выберите DNS-сервер для разрешения доменных имён. Позже это можно изменить в настройках.</string>

    <!-- Onboarding: VPN Permission -->
    <string name="onboarding_vpn_title">Требуется разрешение VPN</string>
    <string name="onboarding_vpn_desc">BlockAds использует локальный VPN для фильтрации DNS-запросов и блокировки рекламы. Данные не покидают устройство — этот VPN работает только локально для перехвата и фильтрации DNS-запросов.</string>
    <string name="onboarding_vpn_grant">Выдать разрешение VPN</string>

    <!-- Onboarding: Notification Permission -->
    <string name="onboarding_notification_title">Будьте в курсе</string>
    <string name="onboarding_notification_desc">Разрешите уведомления, чтобы видеть статистику блокировки в реальном времени и знать, когда защита активна. Необходимо для постоянного VPN-уведомления на Android 13+.</string>
    <string name="onboarding_notification_grant">Разрешить уведомления</string>

    <!-- Onboarding: Battery Optimization -->
    <string name="onboarding_battery_title">Поддерживайте защиту активной</string>
    <string name="onboarding_battery_desc">Исключите BlockAds из оптимизации батареи, чтобы VPN-сервис оставался активным в фоне и не завершался системой.</string>
    <string name="onboarding_battery_grant">Отключить оптимизацию батареи</string>

