    <!-- Onboarding -->
    <string name="onboarding_title_1">Chặn quảng cáo thông minh</string>
    <string name="onboarding_desc_1">Chặn quảng cáo trên tất cả ứng dụng và trình duyệt chỉ với một chạm. Sử dụng công nghệ lọc DNS — không cần root.\n\n🔒 Cam kết bảo mật: Chúng tôi không bao giờ thu thập, lưu trữ hoặc truyền dữ liệu duyệt web của bạn. Mọi xử lý đều diễn ra trên thiết bị của bạn.</string>
    <string name="onboarding_title_2">Quyền riêng tư của bạn, được bảo vệ</string>
    <string name="onboarding_desc_2">Không thu thập dữ liệu. Không theo dõi. Tất cả nhật ký DNS chỉ lưu trên thiết bị của bạn. Chúng tôi không bao giờ xem hoạt động duyệt web của bạn.</string>
    <string name="onboarding_title_3">Miễn phí &amp; Mã nguồn mở</string>
    <string name="onboarding_desc_3">BlockAds hoàn toàn miễn phí, không có mua hàng trong ứng dụng. Mã nguồn được công khai để bất kỳ ai cũng có thể kiểm tra và xác minh.</string>
    <string name="onboarding_skip">Bỏ qua</string>
    <string name="onboarding_next">Tiếp theo</string>
    <string name="onboarding_get_started">Bắt đầu</string>
    <string name="onboarding_recommended">★ Khuyến nghị</string>

    <!-- Onboarding: Protection Level -->
    <string name="onboarding_protection_title">Chọn mức độ bảo vệ</string>
    <string name="onboarding_protection_desc">Chọn mức độ chặn quảng cáo và trình theo dõi</string>
    <string name="onboarding_protection_basic">Cơ bản</string>
    <string name="onboarding_protection_basic_desc">Chặn các mạng quảng cáo lớn. Ít ảnh hưởng đến chức năng trang web.</string>
    <string name="onboarding_protection_standard">Tiêu chuẩn</string>
    <string name="onboarding_protection_standard_desc">Chặn quảng cáo, trình theo dõi và phân tích. Cân bằng tốt giữa bảo vệ và tương thích.</string>
    <string name="onboarding_protection_strict">Nghiêm ngặt</string>
    <string name="onboarding_protection_strict_desc">Chặn tối đa. Có thể ảnh hưởng một số chức năng trang web nhưng bảo vệ mạnh nhất.</string>

    <!-- Onboarding: DNS Server -->
