    <!-- Onboarding: VPN Permission -->
    <string name="onboarding_vpn_title">Cần quyền VPN</string>
    <string name="onboarding_vpn_desc">BlockAds sử dụng VPN cục bộ để lọc truy vấn DNS và chặn quảng cáo. Không có dữ liệu nào rời khỏi thiết bị — VPN này chỉ hoạt động cục bộ để chặn và lọc các yêu cầu DNS.</string>
    <string name="onboarding_vpn_grant">Cấp quyền VPN</string>

    <!-- Onboarding: Notification Permission -->
    <string name="onboarding_notification_title">Luôn cập nhật</string>
    <string name="onboarding_notification_desc">Cho phép thông báo để xem thống kê chặn theo thời gian thực và biết khi nào bảo vệ đang hoạt động. Cần thiết cho thông báo VPN trên Android 13+.</string>
